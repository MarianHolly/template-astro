---
import MainLayout from '@/layouts/main.astro';
import { Button } from '../components/ui/button.tsx';
---

<MainLayout title="Home" description="Welcome to Template Astro">
	<section class="flex flex-col items-center justify-center min-h-[calc(100vh-theme(height.16))] px-4">
		<div class="w-full max-w-2xl space-y-8 text-center">
			<div class="space-y-4">
				<h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
					Welcome to Astro Template
				</h1>
				<p class="mx-auto max-w-xl text-lg text-muted-foreground sm:text-xl">
					A modern, performant starter with Astro, React, Tailwind CSS, and shadcn/ui.
					Build faster with best practices baked in.
				</p>
			</div>

			<div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
				<Button client:load as="a" href="/about">Get Started</Button>
				<Button client:load variant="outline" as="a" href="/contact">Contact Us</Button>
			</div>
		</div>
	</section>
</MainLayout>
